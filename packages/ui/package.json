{
  "name": "@mxv/ui",
  "version": "0.1.0-beta.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/mxvsh/ui"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "src/styles",
    "src/tokens"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./globals.css": "./src/styles/globals.css",
    "./tokens.css": "./src/tokens/tokens.css",
    "./lib/cn": {
      "types": "./dist/lib/cn.d.ts",
      "import": "./dist/lib/cn.js"
    },
    "./layers.css": "./src/tokens/layers.css"
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "radix-ui": "^1.4.3",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "lucide-react": "^0.469.0"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^10.0.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.1.10"
  }
}
