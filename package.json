{
  "name": "mxv-ui",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "dev": "bun run --filter '*' dev",
    "ui:build": "bun run --filter '@mxv/ui' build",
    "ui:dev": "bun run --filter '@mxv/ui' storybook",
    "storybook": "bun run --filter '@mxv/ui' storybook",
    "build-storybook": "bun run --filter '@mxv/ui' build-storybook",
    "playground": "bun run --filter '@mxv/playground' dev",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
